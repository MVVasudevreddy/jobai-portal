# Supabase Configuration
# Get these values from your Supabase project at https://supabase.com

# Your Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase Anonymous/Public Key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Instructions:
# 1. Create a free account at https://supabase.com
# 2. Create a new project (takes ~2 minutes)
# 3. Go to Project Settings > API
# 4. Copy the URL and anon key
# 5. Create a file called .env.local in your project root
# 6. Paste your credentials above (replace the placeholder values)
# 7. Run the SQL schema from BACKEND_SETUP.md in Supabase SQL Editor